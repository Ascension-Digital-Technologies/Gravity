    "/api/errors": { "get": { "summary": "Error catalog", "responses": { "200": { "description": "OK" } } } },
    "/api/routes": { "get": { "summary": "Route inventory", "responses": { "200": { "description": "OK" } } } },
    "/api/openapi": { "get": { "summary": "Generated OpenAPI document", "responses": { "200": { "description": "OK" } } } }
